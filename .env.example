# ── TickTick (register an app at https://developer.ticktick.com/manage) ──
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
TICKTICK_REDIRECT_URI=http://localhost:8080/callback
# Optional: a specific list to route todos into (empty = Inbox)
TICKTICK_DEFAULT_PROJECT_ID=

# ── LLM classifier (cheap model) ──
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL=gemini-1.5-flash

# ── Cloudflare (admin token manages Pages + Access; service token for programmatic access) ──
CF_ADMIN_API_TOKEN=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
CF_ACCOUNT_ID=1c63a21104bcdfd82af9644b7eeed833
CF_PAGES_PROJECT=doing2done-vault
CF_ACCESS_ALLOWED_EMAIL=barundebnath91@gmail.com

OPENROUTER_API_KEY=
