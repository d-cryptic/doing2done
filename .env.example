# ── TickTick (register an app at https://developer.ticktick.com/manage) ──
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
TICKTICK_REDIRECT_URI=http://localhost:8080/callback
# Optional: a specific list to route todos into (empty = Inbox)
TICKTICK_DEFAULT_PROJECT_ID=

# ── LLM classifier (via OpenRouter, OpenAI-compatible) ──
LLM_PROVIDER=openai
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash
LLM_API_KEY=            # your OpenRouter key (sk-or-...)

# ── Cloudflare (admin token manages Pages + Access; service token for programmatic access) ──
CF_ADMIN_API_TOKEN=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
CF_ACCOUNT_ID=REDACTED_ACCOUNT_ID
CF_PAGES_PROJECT=doing2done-vault
CF_ACCESS_ALLOWED_EMAIL=redacted@example.com

OPENROUTER_API_KEY=

HCLOUD_TOKEN=
