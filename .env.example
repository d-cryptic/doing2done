# ── TickTick (register an app at https://developer.ticktick.com/manage) ──
TICKTICK_CLIENT_ID=
TICKTICK_CLIENT_SECRET=
TICKTICK_REDIRECT_URI=http://localhost:8080/callback
# Optional: a specific list to route todos into (empty = Inbox)
TICKTICK_DEFAULT_PROJECT_ID=


# ── Todo provider (pluggable) ──
# ticktick (default) | reminders (Apple Reminders, macOS) | markdown (local file)
TODO_PROVIDER=ticktick
TODO_FILE=            # markdown provider path (default <vault>/todos.md)

# ── LLM classifier (via OpenRouter, OpenAI-compatible) ──
LLM_PROVIDER=openai
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=google/gemini-2.5-flash
LLM_API_KEY=            # your OpenRouter key (sk-or-...)

# ── Cloudflare (admin token manages Pages + Access; service token for programmatic access) ──
CF_ADMIN_API_TOKEN=
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
CF_ACCOUNT_ID=
CF_PAGES_PROJECT=doing2done-vault
CF_ACCESS_ALLOWED_EMAIL=

OPENROUTER_API_KEY=

HCLOUD_TOKEN=

# ── Failure alerting (optional) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PUSHOVER_TOKEN=
PUSHOVER_USER=

# ── 1Password (optional) ──
# Any value above may be a 1Password reference instead of a literal, e.g.:
#   CF_ADMIN_API_TOKEN=op://Private/doing2done/cf_admin_api_token
#   LLM_API_KEY=op://Private/doing2done/openrouter_key
# Requires the `op` CLI installed and signed in.

# ── Cloudflare edge Worker (capture + RAG) ──
WORKER_URL=
INGEST_TOKEN=
