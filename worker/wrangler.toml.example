name = "doing2done"
main = "src/index.ts"
compatibility_date = "2024-11-01"

[[d1_databases]]
binding = "DB"
database_name = "doing2done"
database_id = "<YOUR_D1_DATABASE_ID>"

[ai]
binding = "AI"

[[vectorize]]
binding = "VECTORIZE"
index_name = "doing2done-notes"

[[r2_buckets]]
binding = "ASSETS"
bucket_name = "doing2done-assets"
